{
  "entities": {
    "Testimonial": {
      "title": "Testimonial",
      "description": "Client feedback and results.",
      "type": "object",
      "properties": {
        "author": { "type": "string" },
        "role": { "type": "string" },
        "content": { "type": "string" },
        "rating": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["author", "content"]
    },
    "Service": {
      "title": "Service",
      "description": "Offered services by the agency.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title"]
    },
    "PortfolioItem": {
      "title": "Portfolio Item",
      "description": "Showcase of past work.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "year": { "type": "string" },
        "full_description": { "type": "string" },
        "challenge_text": { "type": "string" },
        "solution_text": { "type": "string" },
        "tech_stack": { "type": "array", "items": { "type": "string" } },
        "gallery": { "type": "array", "items": { "type": "string" } },
        "client_name": { "type": "string" },
        "client_testimonial": { "type": "string" },
        "og_image": { "type": "string" },
        "og_description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "slug"]
    },
    "SiteSetting": {
      "title": "Site Setting",
      "description": "Key-value pair for site content. Common keys: about_manifesto, about_vision, about_mission, about_dna, seo_title, seo_description, analytics_id, is_maintenance_mode.",
      "type": "object",
      "properties": {
        "key": { "type": "string" },
        "value": { "type": "string" }
      },
      "required": ["key", "value"]
    },
    "NavigationLink": {
      "title": "Navigation Link",
      "description": "Links for Navbar or Footer.",
      "type": "object",
      "properties": {
        "label": { "type": "string" },
        "path": { "type": "string" },
        "order": { "type": "number" },
        "isActive": { "type": "boolean" },
        "type": { "type": "string", "enum": ["header", "footer", "legal"] }
      },
      "required": ["label", "path", "order", "type"]
    },
    "MediaAsset": {
      "title": "Media Asset",
      "description": "Metadata for uploaded files.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "url": { "type": "string" },
        "type": { "type": "string" },
        "size": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "uploadedBy": { "type": "string" }
      },
      "required": ["name", "url", "type", "size", "createdAt", "uploadedBy"]
    },
    "Client": {
      "title": "Client",
      "description": "Business client information.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "company": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email"]
    },
    "Project": {
      "title": "Project",
      "description": "Client project details.",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "client_name": { "type": "string" },
        "client_email": { "type": "string", "format": "email" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "completed", "on-hold", "discovery"] },
        "budget": { "type": "number" },
        "deadline": { "type": "string", "format": "date" },
        "current_step": { "type": "number" },
        "assets": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "url": { "type": "string" },
              "size": { "type": "number" },
              "type": { "type": "string" },
              "uploadedAt": { "type": "string", "format": "date-time" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientId", "title"]
    },
    "Billing": {
      "title": "Billing",
      "description": "Invoice or payment record.",
      "type": "object",
      "properties": {
        "project_id": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["paid", "unpaid"] },
        "dueDate": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "amount"]
    },
    "Message": {
      "title": "Message",
      "description": "Contact form submissions.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["new", "read", "replied"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "message"]
    },
    "Post": {
      "title": "Blog Post",
      "description": "Article for the agency journal.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "content": { "type": "string" },
        "excerpt": { "type": "string" },
        "category": { "type": "string" },
        "author": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["draft", "published"] },
        "featuredImage": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "og_image": { "type": "string" },
        "og_description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "slug", "content"]
    },
    "ActivityLog": {
      "title": "Activity Log",
      "description": "Record of administrative actions.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "action": { "type": "string" },
        "targetCollection": { "type": "string" },
        "targetId": { "type": "string" },
        "details": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "action", "timestamp"]
    },
    "NewsletterLead": {
      "title": "Newsletter Lead",
      "description": "Subscription for news and updates.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "status": { "type": "string", "enum": ["active", "unsubscribed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "createdAt"]
    },
    "Admin": {
      "title": "Administrator",
      "description": "System administrator account.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" }
      },
      "required": ["name", "email"]
    }
  },
  "firestore": {
    "admins": {
      "schema": "Admin",
      "description": "Authorized administrative accounts."
    },
    "testimonials": {
      "schema": "Testimonial",
      "description": "Public testimonials."
    },
    "services": {
      "schema": "Service",
      "description": "Services offered."
    },
    "portfolio": {
      "schema": "PortfolioItem",
      "description": "Portfolio work."
    },
    "navigation": {
      "schema": "NavigationLink",
      "description": "Site navigation links."
    },
    "media": {
      "schema": "MediaAsset",
      "description": "Uploaded media library."
    },
    "settings": {
      "schema": "SiteSetting",
      "description": "General site settings."
    },
    "clients": {
      "schema": "Client",
      "description": "Internal client list."
    },
    "projects": {
      "schema": "Project",
      "description": "Internal projects."
    },
    "billing": {
      "schema": "Billing",
      "description": "Internal billing records."
    },
    "messages": {
      "schema": "Message",
      "description": "Inbound leads."
    },
    "posts": {
      "schema": "Post",
      "description": "Journal articles."
    },
    "activity_logs": {
      "schema": "ActivityLog",
      "description": "Administrative audit trail."
    },
    "newsletter_leads": {
      "schema": "NewsletterLead",
      "description": "Marketing leads."
    }
  }
}
