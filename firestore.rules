rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ---------------------------------------------------------
    // GLOBAL HELPERS
    // ---------------------------------------------------------
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email == 'diffuseagency@gmail.com';
    }

    function isAdmin() {
      return isSuperAdmin() || exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ---------------------------------------------------------
    // VALIDATION HELPERS
    // ---------------------------------------------------------
    
    function isValidPortfolio(doc) {
      return doc.keys().hasAll(['title', 'slug']) &&
             doc.title is string && doc.title.size() <= 200 &&
             doc.slug is string && doc.slug.size() <= 200 &&
             (doc.get('category', '') is string) &&
             (doc.get('image', '') is string) &&
             (doc.get('year', '') is string) &&
             (doc.get('full_description', '') is string) &&
             (doc.get('challenge_text', '') is string) &&
             (doc.get('solution_text', '') is string) &&
             (doc.get('tech_stack', []) is list) &&
             (doc.get('gallery', []) is list) &&
             (doc.get('og_image', '') is string) &&
             (doc.get('og_description', '') is string) &&
             (doc.get('client_name', '') is string);
    }

    function isValidService(doc) {
      return doc.keys().hasAll(['title']) &&
             doc.title is string && doc.title.size() <= 200 &&
             (doc.get('description', '') is string) &&
             (doc.get('icon', '') is string) &&
             (doc.get('features', []) is list);
    }

    function isValidTestimonial(doc) {
      return doc.keys().hasAll(['author', 'content']) &&
             doc.author is string && doc.author.size() <= 100 &&
             doc.content is string && doc.content.size() <= 1000 &&
             (doc.get('role', '') is string) &&
             (doc.get('avatar', '') is string) &&
             (doc.get('rating', 5) is int);
    }

    function isValidSetting(doc) {
      return doc.keys().hasAll(['key', 'value']) &&
             doc.key is string && doc.key.size() <= 100 &&
             doc.value is string && doc.value.size() <= 10000;
    }

    function isValidNavigationLink(doc) {
      return doc.keys().hasAll(['label', 'path', 'order', 'type']) &&
             doc.label is string && doc.label.size() <= 50 &&
             doc.path is string && doc.path.size() <= 100 &&
             doc.order is int &&
             doc.type in ['header', 'footer', 'legal'] &&
             (doc.get('isActive', true) is bool);
    }

    function isValidMediaAsset(doc) {
      return doc.keys().hasAll(['name', 'url', 'type', 'size', 'createdAt', 'uploadedBy']) &&
             doc.name is string && doc.name.size() <= 255 &&
             doc.url is string && doc.url.size() <= 1000 &&
             doc.type is string &&
             doc.size is int &&
             doc.uploadedBy == request.auth.uid;
    }

    function isValidClient(doc) {
      return doc.keys().hasAll(['name', 'email']) &&
             doc.name is string && doc.name.size() <= 100 &&
             doc.email is string && doc.email.size() <= 100 &&
             (doc.get('company', '') is string);
    }

    function isValidProject(doc) {
      return doc.keys().hasAll(['client_id', 'title', 'client_email']) &&
             doc.client_id is string && isValidId(doc.client_id) &&
             doc.client_email is string && doc.client_email.size() <= 100 &&
             doc.title is string && doc.title.size() <= 200 &&
             (doc.get('status', 'active') in ['active', 'completed', 'on-hold', 'discovery']) &&
             (doc.get('current_step', 0) is int) &&
             (doc.get('assets', []) is list);
    }

    function isValidBilling(doc) {
      return doc.keys().hasAll(['project_id', 'amount']) &&
             doc.project_id is string && isValidId(doc.project_id) &&
             doc.amount is number &&
             (doc.get('status', 'unpaid') in ['paid', 'unpaid', 'overdue']);
    }

    function isValidMessage(doc) {
      return doc.keys().hasAll(['name', 'email', 'message']) &&
             doc.name is string && doc.name.size() <= 100 &&
             doc.email is string && doc.email.size() <= 100 &&
             doc.message is string && doc.message.size() <= 2000 &&
             (doc.get('subject', '') is string) &&
             (doc.get('status', 'new') in ['new', 'read', 'replied']);
    }

    function isValidPost(doc) {
      return doc.keys().hasAll(['title', 'slug', 'content']) &&
             doc.title is string && doc.title.size() <= 200 &&
             doc.slug is string && doc.slug.size() <= 200 &&
             doc.content is string && doc.content.size() <= 100000 &&
             (doc.get('excerpt', '') is string) &&
             (doc.get('category', '') is string) &&
             (doc.get('author', '') is string) &&
             (doc.get('status', 'draft') in ['draft', 'published']) &&
             (doc.get('featuredImage', '') is string) &&
             (doc.get('og_image', '') is string) &&
             (doc.get('og_description', '') is string) &&
             (doc.get('tags', []) is list);
    }

    function isValidActivityLog(doc) {
      return doc.keys().hasAll(['userId', 'action', 'timestamp']) &&
             doc.userId is string &&
             doc.action is string &&
             doc.timestamp is timestamp;
    }

    function isValidNewsletterLead(doc) {
      return doc.keys().hasAll(['email', 'createdAt']) &&
             doc.email is string && doc.email.size() <= 100 &&
             doc.createdAt is timestamp &&
             (doc.get('status', 'active') in ['active', 'unsubscribed']);
    }

    function isValidAdmin(doc) {
      return doc.keys().hasAll(['name', 'email']) &&
             doc.name is string && doc.name.size() <= 100 &&
             doc.email is string && doc.email.size() <= 100;
    }

    // ---------------------------------------------------------
    // ROUTES
    // ---------------------------------------------------------

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /admins/{adminId} {
      allow list: if isAdmin();
      allow get: if isAdmin() || (isSignedIn() && request.auth.uid == adminId);
      allow create, update: if isAdmin() && isValidAdmin(incoming());
      allow delete: if isAdmin() && adminId != request.auth.uid;
    }

    match /messages/{messageId} {
      allow list, get, update, delete: if isAdmin();
      allow create: if isValidMessage(incoming()) && isValidId(messageId) &&
                       incoming().createdAt == request.time;
    }

    match /portfolio/{itemId} {
      allow read: if true;
      allow create: if isAdmin() && isValidPortfolio(incoming()) && isValidId(itemId) &&
                       incoming().createdAt == request.time;
      allow update: if isAdmin() && isValidPortfolio(incoming()) &&
                       incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if true;
      allow create: if isAdmin() && isValidService(incoming()) && isValidId(serviceId) &&
                       incoming().createdAt == request.time;
      allow update: if isAdmin() && isValidService(incoming()) &&
                       incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin();
    }

    match /testimonials/{testId} {
      allow read: if true;
      allow create: if isAdmin() && isValidTestimonial(incoming()) && isValidId(testId) &&
                       incoming().createdAt == request.time;
      allow update: if isAdmin() && isValidTestimonial(incoming()) &&
                       incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow create: if isAdmin() && isValidSetting(incoming()) && isValidId(settingId);
      allow update: if isAdmin() && isValidSetting(incoming());
      allow delete: if isAdmin();
    }

    match /navigation/{linkId} {
      allow read: if true;
      allow create: if isAdmin() && isValidNavigationLink(incoming()) && isValidId(linkId);
      allow update: if isAdmin() && isValidNavigationLink(incoming());
      allow delete: if isAdmin();
    }

    match /media/{assetId} {
      allow list, get, create, delete: if isAdmin();
      allow update: if false;
    }

    match /clients/{clientId} {
      allow get: if isAdmin() || (isSignedIn() && resource.data.email == request.auth.token.email);
      allow list: if isAdmin() || (isSignedIn() && resource.data.email == request.auth.token.email);
      allow create: if isAdmin() && isValidClient(incoming()) && isValidId(clientId) &&
                       incoming().createdAt == request.time;
      allow update: if isAdmin() && isValidClient(incoming()) &&
                       incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin();
    }

    match /projects/{projectId} {
      allow get: if isAdmin() || (isSignedIn() && existing().client_email == request.auth.token.email);
      allow list: if isAdmin() || (isSignedIn() && resource.data.client_email == request.auth.token.email);
      allow create: if isAdmin() && isValidProject(incoming()) && isValidId(projectId) &&
                       incoming().createdAt == request.time;
      allow update: if (isAdmin() && isValidProject(incoming()) && incoming().createdAt == existing().createdAt) ||
                       (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['assets']) && isValidProject(incoming()) && incoming().createdAt == existing().createdAt);
      allow delete: if isAdmin();
    }

    match /billing/{billId} {
      allow get: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/projects/$(existing().project_id)).data.client_email == request.auth.token.email);
      allow list: if isAdmin();
      allow create: if isAdmin() && isValidBilling(incoming()) && isValidId(billId) &&
                       incoming().createdAt == request.time;
      allow update: if isAdmin() && isValidBilling(incoming()) &&
                       incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin();
    }

    match /posts/{postId} {
      allow get: if isAdmin() || resource.data.status == 'published';
      allow list: if isAdmin() || resource.data.status == 'published';
      allow create: if isAdmin() && isValidPost(incoming()) && isValidId(postId) &&
                       incoming().createdAt == request.time;
      allow update: if isAdmin() && isValidPost(incoming()) &&
                       incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin();
    }

    match /activity_logs/{logId} {
      allow read, create: if isAdmin();
      allow update, delete: if false;
    }

    match /newsletter_leads/{leadId} {
      allow list, get, update, delete: if isAdmin();
      allow create: if isValidNewsletterLead(incoming()) && 
                       incoming().createdAt == request.time;
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
